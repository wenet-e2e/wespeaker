<?xml version="1.0" encoding="utf-8"?>
<!-- WeNet-style palette: deep blue primary + teal accent; see https://wenet.org.cn/ -->
<resources>
    <color name="black">#FF000000</color>
    <color name="white">#FFFFFFFF</color>

    <!-- Primary: deep sea blue -->
    <color name="wenet_primary">#1565C0</color>
    <color name="wenet_primary_dark">#0D47A1</color>
    <color name="wenet_primary_light">#42A5F5</color>
    <color name="wenet_on_primary">#FFFFFF</color>
    <color name="wenet_primary_container">#E3F2FD</color>
    <color name="wenet_on_primary_container">#0D47A1</color>

    <!-- Secondary: teal (matches site blue-green gradient) -->
    <color name="wenet_secondary">#00897B</color>
    <color name="wenet_secondary_dark">#00695C</color>
    <color name="wenet_on_secondary">#FFFFFF</color>
    <color name="wenet_secondary_container">#E0F2F1</color>
    <color name="wenet_on_secondary_container">#004D40</color>

    <!-- Surfaces and text -->
    <color name="wenet_background">#F0F4F8</color>
    <color name="wenet_surface">#FFFFFF</color>
    <color name="wenet_surface_variant">#ECEFF1</color>
    <color name="wenet_on_background">#1C2833</color>
    <color name="wenet_on_surface">#1C2833</color>
    <color name="wenet_on_surface_variant">#546E7A</color>
    <color name="wenet_outline">#CFD8DC</color>

    <!-- Result emphasis -->
    <color name="wenet_success">#2E7D32</color>
    <color name="wenet_result_card">#FAFCFE</color>

    <!-- Legacy aliases (theme uses wenet_* names) -->
    <color name="purple_200">#FFBB86FC</color>
    <color name="purple_500">@color/wenet_primary</color>
    <color name="purple_700">@color/wenet_primary_dark</color>
    <color name="teal_200">@color/wenet_secondary_container</color>
    <color name="teal_700">@color/wenet_secondary</color>
</resources>
